{
  "name": "nsight-mcp-server",
  "version": "0.1.0",
  "description": "N-sight AI Connect — Official MCP server for N-able N-sight RMM",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:readonly": "node dist/readonly-server.js",
    "start:production": "node dist/production-server.js",
    "dev:readonly": "tsx src/readonly-server.ts",
    "dev:production": "tsx src/production-server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/xml2js": "^0.4.14",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "n-able",
    "nsight",
    "rmm",
    "msp",
    "model-context-protocol"
  ],
  "author": "N-able Technologies",
  "license": "UNLICENSED",
  "private": true
}
